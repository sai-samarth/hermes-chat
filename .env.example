# Local Hermes bridge URL used by the Next.js backend.
HERMES_BRIDGE_URL=http://127.0.0.1:8643

# Optional shared secret sent to the bridge in the X-Hermes-Bridge-Key header.
HERMES_BRIDGE_API_KEY=

# Optional baseline Hermes profile to clone when a new app user gets their
# first isolated Hermes profile. Defaults to `default` when unset.
HERMES_BRIDGE_BASELINE_PROFILE=default

# Optional Hermes CLI command override for the bridge.
HERMES_BRIDGE_HERMES_CMD=hermes

# Optional localhost-only bridge bind settings.
HERMES_BRIDGE_HOST=127.0.0.1
HERMES_BRIDGE_PORT=8643

# Optional SQLite file path. Relative paths resolve from the project root.
# Defaults to ./data/hermes-chat.sqlite when unset.
SQLITE_DB_PATH=./data/hermes-chat.sqlite

# Optional local auth session lifetime in days.
# Defaults to 30 days when unset.
AUTH_SESSION_TTL_DAYS=30

# Optional session cookie security override.
# Defaults to secure cookies on HTTPS requests and plain cookies on localhost/http.
AUTH_COOKIE_SECURE=
